---
import Layout from '../layouts/Layout.astro';
---

<Layout title="FactureArtisan | Créez vos devis et factures en 2 minutes">
  <div class="hero container">
    <div class="hero-content">
      <h1 class="text-gradient">Des factures pros, <br/><span class="text-gradient-primary">sans prise de tête.</span></h1>
      <p class="subtitle">Le générateur de factures conçu pour les artisans et indépendants. Créez des documents impeccables en PDF, gratuitement.</p>
      
      <div class="hero-actions">
        <a href="/app" class="btn btn-primary btn-lg">Créer ma première facture</a>
        <p class="micro-copy">100% gratuit pour vos 3 premières factures. Sans carte bancaire.</p>
      </div>
    </div>
    
    <div class="hero-preview glass-card">
      <div class="preview-header">
        <div class="dots">
          <span></span><span></span><span></span>
        </div>
        <div class="preview-title">Aperçu Facture</div>
      </div>
      <div class="preview-body">
        <div class="skeleton title"></div>
        <div class="skeleton-row">
          <div class="skeleton box"></div>
          <div class="skeleton box"></div>
        </div>
        <div class="skeleton line"></div>
        <div class="skeleton line"></div>
        <div class="skeleton line short"></div>
      </div>
    </div>
  </div>

  <section class="container" style="padding: 60px 24px; text-align: center;">
    <h2 style="margin-bottom: 20px;">Des modèles conçus pour impressionner</h2>
    <p style="color: var(--text-muted); margin-bottom: 40px; max-width: 600px; margin-left: auto; margin-right: auto;">
      La version gratuite inclut notre modèle Standard. Passez à la version Pro pour débloquer la personnalisation, les couleurs de votre marque et votre logo.
    </p>
    
    <div class="templates-grid">
      <!-- Modèle Classique -->
      <div class="template-card">
        <div class="template-preview" style="background: #fff; color: #333;">
          <div style="height: 10px; width: 40%; background: #ddd; margin-bottom: 10px;"></div>
          <div style="height: 2px; width: 100%; background: #eee; margin-bottom: 10px;"></div>
          <div style="height: 30px; width: 100%; background: #f5f5f5;"></div>
        </div>
        <div class="template-info">
          <h4>Standard</h4>
          <span class="badge-free">Gratuit</span>
        </div>
      </div>

      <!-- Modèle Premium -->
      <div class="template-card locked">
        <div class="template-preview" style="background: #2a2a35; color: #fff;">
          <div style="height: 15px; width: 30%; background: var(--primary); margin-bottom: 10px; border-radius: 2px;"></div>
          <div style="height: 2px; width: 100%; background: #444; margin-bottom: 10px;"></div>
          <div style="height: 30px; width: 100%; background: #333;"></div>
          <div class="lock-icon">🔒</div>
        </div>
        <div class="template-info">
          <h4>Premium Sombre</h4>
          <span class="badge-pro">PRO</span>
        </div>
      </div>

      <!-- Modèle Épuré -->
      <div class="template-card locked">
        <div class="template-preview" style="background: #fdfdfd; border: 1px solid #e0e0e0;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
            <div style="height: 15px; width: 20%; background: #ccc; border-radius: 50%;"></div>
            <div style="height: 10px; width: 30%; background: #eee;"></div>
          </div>
          <div style="height: 30px; width: 100%; background: #fafafa;"></div>
          <div class="lock-icon">🔒</div>
        </div>
        <div class="template-info">
          <h4>Épuré + Logo</h4>
          <span class="badge-pro">PRO</span>
        </div>
      </div>
    </div>
  </section>

  <section class="features container">
    <h2>Pourquoi choisir FactureArtisan ?</h2>
    <div class="features-grid">
      <div class="feature-card glass-card">
        <h3>⚡ Ultra Rapide</h3>
        <p>Ne perdez plus de temps sur Excel. Remplissez le formulaire, votre PDF est prêt instantanément.</p>
      </div>
      <div class="feature-card glass-card">
        <h3>🎨 Design Pro</h3>
        <p>Vos clients méritent des documents propres. Notre modèle premium met en valeur votre sérieux.</p>
      </div>
      <div class="feature-card glass-card">
        <h3>🔒 Sécurisé</h3>
        <p>Vos données sont protégées. Gardez un historique de toutes vos factures avec le compte Pro.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    padding: 80px 24px;
    min-height: calc(100vh - 200px);
  }
  
  .hero-content h1 {
    font-size: 3.5rem;
    margin-bottom: 24px;
  }
  
  .subtitle {
    font-size: 1.2rem;
    color: var(--text-muted);
    margin-bottom: 40px;
    max-width: 500px;
  }
  
  .btn-lg {
    padding: 16px 32px;
    font-size: 1.1rem;
  }
  
  .micro-copy {
    margin-top: 12px;
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  
  /* Preview Animation Mockup */
  .hero-preview {
    width: 100%;
    aspect-ratio: 4/5;
    background: rgba(255, 255, 255, 0.02);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  
  .preview-header {
    background: rgba(0, 0, 0, 0.3);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border);
  }
  
  .dots {
    display: flex;
    gap: 6px;
  }
  
  .dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #ff5f56;
  }
  .dots span:nth-child(2) { background: #ffbd2e; }
  .dots span:nth-child(3) { background: #27c93f; }
  
  .preview-title {
    flex: 1;
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  
  .preview-body {
    padding: 30px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  
  .skeleton {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
  }
  
  .skeleton.title {
    height: 30px;
    width: 40%;
    margin-bottom: 20px;
  }
  
  .skeleton-row {
    display: flex;
    gap: 20px;
    margin-bottom: 30px;
  }
  
  .skeleton.box {
    height: 80px;
    flex: 1;
  }
  
  .skeleton.line {
    height: 12px;
    width: 100%;
  }
  
  .skeleton.short {
    width: 60%;
  }
  
  /* Features */
  .features {
    padding: 80px 24px;
    text-align: center;
  }
  
  .features h2 {
    margin-bottom: 50px;
  }
  
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  
  .feature-card {
    padding: 40px 30px;
    text-align: left;
    transition: transform 0.3s ease;
  }
  
  .feature-card:hover {
    transform: translateY(-5px);
  }
  
  .feature-card h3 {
    color: var(--primary);
    margin-bottom: 16px;
    font-size: 1.3rem;
  }
  
  /* Templates Showcase */
  .templates-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    text-align: left;
  }
  .template-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 15px;
    color: var(--text-main);
  }
  .template-preview {
    height: 100px;
    border-radius: 6px;
    padding: 10px;
    margin-bottom: 12px;
    position: relative;
    overflow: hidden;
  }
  .locked .template-preview {
    opacity: 0.7;
  }
  .lock-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 2rem;
    opacity: 0.9;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
  }
  .template-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .template-info h4 {
    font-size: 0.95rem;
    margin: 0;
  }
  .badge-free {
    font-size: 0.7rem;
    background: #ffffff1a;
    padding: 3px 8px;
    border-radius: 12px;
  }
  .badge-pro {
    font-size: 0.7rem;
    background: var(--primary);
    color: white;
    padding: 3px 8px;
    border-radius: 12px;
    font-weight: bold;
  }
  
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      text-align: center;
    }
    
    .subtitle {
      margin: 0 auto 40px auto;
    }
    
    .features-grid, .templates-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
