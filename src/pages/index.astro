---
import Layout from '../layouts/Layout.astro';
import TemplateShowcase from '../components/TemplateShowcase.astro';
---

<Layout 
  title="FactureArtisan | Créez vos devis et factures en 2 minutes"
  description="Générez des factures PDF professionnelles en quelques clics. Gratuit, sans inscription requise. Modèles conformes aux normes suisses avec TVA 8.1%. Idéal pour artisans et indépendants."
>
  <div class="hero container">
    <div class="hero-content">
      <h1 class="text-gradient">Des factures pros, <br/><span class="text-gradient-primary">sans prise de tête.</span></h1>
      <p class="subtitle">Le générateur de factures conçu pour les artisans et indépendants. Créez des documents impeccables en PDF, gratuitement.</p>
      
      <div class="hero-actions">
        <a href="/app" class="btn btn-primary btn-lg">Créer ma première facture</a>
        <p class="micro-copy">100% gratuit pour vos 3 premières factures. Sans carte bancaire.</p>
      </div>
    </div>
    
    <div class="hero-preview glass-card">
      <div class="preview-header">
        <div class="dots">
          <span></span><span></span><span></span>
        </div>
        <div class="preview-title">Aperçu — Modèle Pro</div>
        <span class="preview-badge">✨ PRO</span>
      </div>
      <div class="preview-body">
        <!-- Invoice mockup -->
        <div class="inv-mock">

          <!-- Header: Logo + Title + Client -->
          <div class="inv-mock-header">
            <div class="inv-mock-left">
              <div class="inv-mock-logo">
                <span>🏗️</span>
                <strong>Dupont Construction</strong>
              </div>
              <div class="inv-mock-meta">
                <span>Route de Genève 42, 1004 Lausanne</span>
                <span>contact@dupont.ch</span>
                <span>IBAN: CH56 0483 5012 3456 7800 9</span>
              </div>
            </div>
            <div class="inv-mock-right">
              <div class="inv-mock-title">FACTURE</div>
              <div class="inv-mock-info">
                <span>N° 2026-047</span>
                <span>10 juillet 2026</span>
              </div>
              <div class="inv-mock-client">
                <strong>Facturé à :</strong>
                <span>M. Bernard Müller</span>
                <span>Av. des Alpes 17</span>
                <span>1200 Genève</span>
              </div>
            </div>
          </div>

          <!-- Table -->
          <div class="inv-mock-table">
            <div class="inv-mock-table-head">
              <span class="col-desc">Description</span>
              <span class="col-qty">Qté</span>
              <span class="col-price">Prix U.</span>
              <span class="col-total">Total</span>
            </div>
            <div class="inv-mock-row">
              <span class="col-desc">Pose de carrelage salle de bain</span>
              <span class="col-qty">1</span>
              <span class="col-price">1 800 CHF</span>
              <span class="col-total">1 800.00 CHF</span>
            </div>
            <div class="inv-mock-row">
              <span class="col-desc">Fournitures et matériaux</span>
              <span class="col-qty">1</span>
              <span class="col-price">450 CHF</span>
              <span class="col-total">450.00 CHF</span>
            </div>
            <div class="inv-mock-row">
              <span class="col-desc">Main d'œuvre supplémentaire (4h)</span>
              <span class="col-qty">4</span>
              <span class="col-price">95 CHF</span>
              <span class="col-total">380.00 CHF</span>
            </div>
          </div>

          <!-- Totals -->
          <div class="inv-mock-totals">
            <div class="inv-mock-total-row">
              <span>Sous-total :</span>
              <span>2 630.00 CHF</span>
            </div>
            <div class="inv-mock-total-row">
              <span>TVA (8.1%) :</span>
              <span>213.03 CHF</span>
            </div>
            <div class="inv-mock-total-row grand">
              <span>Total TTC :</span>
              <span>2 843.03 CHF</span>
            </div>
          </div>

          <div class="inv-mock-note">
            Paiement sous 30 jours. Merci de votre confiance.
          </div>
        </div>
      </div>
    </div>

  </div>

  <section class="container" style="padding: 60px 24px; text-align: center;">
    <h2 style="margin-bottom: 20px;">Des modèles conçus pour impressionner</h2>
    <p style="color: var(--text-muted); margin-bottom: 40px; max-width: 600px; margin-left: auto; margin-right: auto;">
      Le modèle Standard est gratuit. La version Pro débloque les modèles avec logo et format enveloppe suisse (C5), optimisés pour les fenêtres d'enveloppes.
    </p>
    
    <TemplateShowcase />
  </section>

  <section class="features container">
    <h2>Pourquoi choisir FactureArtisan ?</h2>
    <div class="features-grid">
      <div class="feature-card glass-card">
        <h3>⚡ Ultra Rapide</h3>
        <p>Ne perdez plus de temps sur Excel. Remplissez le formulaire, votre PDF est prêt instantanément.</p>
      </div>
      <div class="feature-card glass-card">
        <h3>🎨 Design Pro</h3>
        <p>Vos clients méritent des documents propres. Notre modèle premium met en valeur votre sérieux.</p>
      </div>
      <div class="feature-card glass-card">
        <h3>🔒 Sécurisé</h3>
        <p>Vos données sont protégées. Gardez un historique de toutes vos factures avec le compte Pro.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    padding: 80px 24px;
    min-height: calc(100vh - 200px);
  }
  
  .hero-content h1 {
    font-size: 3.5rem;
    margin-bottom: 24px;
  }
  
  .subtitle {
    font-size: 1.2rem;
    color: var(--text-muted);
    margin-bottom: 40px;
    max-width: 500px;
  }
  
  .btn-lg {
    padding: 16px 32px;
    font-size: 1.1rem;
  }
  
  .micro-copy {
    margin-top: 12px;
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  
  /* Preview Animation Mockup */
  .hero-preview {
    width: 100%;
    aspect-ratio: 4/5;
    background: rgba(255, 255, 255, 0.02);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  
  .preview-header {
    background: rgba(0, 0, 0, 0.3);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border);
  }
  
  .dots {
    display: flex;
    gap: 6px;
  }
  
  .dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #ff5f56;
  }
  .dots span:nth-child(2) { background: #ffbd2e; }
  .dots span:nth-child(3) { background: #27c93f; }
  
  .preview-title {
    flex: 1;
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .preview-badge {
    background: var(--primary);
    color: white;
    font-size: 0.7rem;
    font-weight: bold;
    padding: 2px 8px;
    border-radius: 20px;
    letter-spacing: 0.5px;
  }

  
  .preview-body {
    padding: 30px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  
  .inv-mock {
    background: #ffffff;
    border-radius: 4px;
    padding: 24px;
    color: #1a1a2e; /* Light theme text for invoice */
    font-size: 0.75rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .inv-mock-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 30px;
  }

  .inv-mock-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1.1rem;
    margin-bottom: 12px;
  }

  .inv-mock-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: #6b6b80;
  }

  .inv-mock-right {
    text-align: right;
  }

  .inv-mock-title {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--primary);
    margin-bottom: 12px;
  }

  .inv-mock-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 16px;
    color: #6b6b80;
  }

  .inv-mock-client {
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: #f5f5f7;
    padding: 12px;
    border-radius: 4px;
    text-align: left;
  }

  .inv-mock-table {
    margin-bottom: 24px;
  }

  .inv-mock-table-head {
    display: flex;
    border-bottom: 2px solid #e2e2e8;
    padding-bottom: 8px;
    margin-bottom: 8px;
    font-weight: bold;
    color: #6b6b80;
  }

  .inv-mock-row {
    display: flex;
    border-bottom: 1px solid #f5f5f7;
    padding: 8px 0;
  }

  .col-desc { flex: 1; }
  .col-qty { width: 40px; text-align: center; }
  .col-price { width: 80px; text-align: right; }
  .col-total { width: 90px; text-align: right; }

  .inv-mock-totals {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    margin-bottom: 30px;
  }

  .inv-mock-total-row {
    display: flex;
    justify-content: space-between;
    width: 200px;
  }

  .inv-mock-total-row.grand {
    font-weight: bold;
    font-size: 0.9rem;
    border-top: 2px solid #e2e2e8;
    padding-top: 8px;
    margin-top: 4px;
  }

  .inv-mock-note {
    color: #6b6b80;
    font-style: italic;
    border-top: 1px solid #f5f5f7;
    padding-top: 16px;
  }
  
  /* Features */
  .features {
    padding: 80px 24px;
    text-align: center;
  }
  
  .features h2 {
    margin-bottom: 50px;
  }
  
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  
  .feature-card {
    padding: 40px 30px;
    text-align: left;
    transition: transform 0.3s ease;
  }
  
  .feature-card:hover {
    transform: translateY(-5px);
  }
  
  .feature-card h3 {
    color: var(--primary);
    margin-bottom: 16px;
    font-size: 1.3rem;
  }
  
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      text-align: center;
    }
    
    .subtitle {
      margin: 0 auto 40px auto;
    }
    
    .features-grid, .templates-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
