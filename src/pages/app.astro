---
import Layout from '../layouts/Layout.astro';
import InvoiceApp from '../components/InvoiceApp';

// Server-side authentication check
const accessToken = Astro.cookies.get('sb-access-token');
const refreshToken = Astro.cookies.get('sb-refresh-token');

if (!accessToken || !refreshToken) {
  return Astro.redirect('/login');
}
---

<Layout title="FactureArtisan | Éditeur de facture">
  <div class="container" style="padding: 40px 24px;">
    <div class="app-header-simple" style="margin-bottom: 30px;">
      <h1 class="text-gradient">Nouvelle Facture</h1>
      <p style="color: var(--text-muted);">Remplissez les champs ci-dessous pour générer votre document PDF.</p>
    </div>

    <!-- Sélecteur de modèles (Templates Showcase) -->
    <div class="templates-showcase" style="margin-bottom: 40px;">
      <h3 style="margin-bottom: 15px; font-size: 1.1rem; color: var(--text-main);">Choisissez votre modèle</h3>
      <div class="templates-grid">
        
        <!-- Modèle Classique (Gratuit) -->
        <div class="template-card active">
          <div class="template-preview" style="background: #fff; color: #333;">
            <div style="height: 10px; width: 40%; background: #ddd; margin-bottom: 10px;"></div>
            <div style="height: 2px; width: 100%; background: #eee; margin-bottom: 10px;"></div>
            <div style="height: 30px; width: 100%; background: #f5f5f5;"></div>
          </div>
          <div class="template-info">
            <h4>Standard</h4>
            <span class="badge-free">Gratuit</span>
          </div>
        </div>

        <!-- Modèle Premium (Pro) -->
        <a href="/pro" class="template-card locked">
          <div class="template-preview" style="background: #2a2a35; color: #fff;">
            <div style="height: 15px; width: 30%; background: var(--primary); margin-bottom: 10px; border-radius: 2px;"></div>
            <div style="height: 2px; width: 100%; background: #444; margin-bottom: 10px;"></div>
            <div style="height: 30px; width: 100%; background: #333;"></div>
            <div class="lock-icon">🔒</div>
          </div>
          <div class="template-info">
            <h4>Premium Sombre</h4>
            <span class="badge-pro">PRO</span>
          </div>
        </a>

        <!-- Modèle Épuré (Pro) -->
        <a href="/pro" class="template-card locked">
          <div class="template-preview" style="background: #fdfdfd; border: 1px solid #e0e0e0;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
              <div style="height: 15px; width: 20%; background: #ccc; border-radius: 50%;"></div>
              <div style="height: 10px; width: 30%; background: #eee;"></div>
            </div>
            <div style="height: 30px; width: 100%; background: #fafafa;"></div>
            <div class="lock-icon">🔒</div>
          </div>
          <div class="template-info">
            <h4>Épuré + Logo</h4>
            <span class="badge-pro">PRO</span>
          </div>
        </a>

      </div>
      <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 15px;">
        💡 <strong>Astuce :</strong> La personnalisation avancée (couleurs, logo d'entreprise, design) est exclusive à la version Pro.
      </p>
    </div>
    
    <!-- Render React app exclusively on client-side to prevent SSR issues with @react-pdf/renderer -->
    <InvoiceApp client:only="react" />
  </div>
<style>
  .templates-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .template-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 15px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    color: var(--text-main);
    display: block;
  }
  .template-card:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
  }
  .template-card.active {
    border-color: var(--primary);
    box-shadow: 0 0 15px var(--primary-glow);
  }
  .template-preview {
    height: 100px;
    border-radius: 6px;
    padding: 10px;
    margin-bottom: 12px;
    position: relative;
    overflow: hidden;
  }
  .locked .template-preview {
    opacity: 0.7;
  }
  .lock-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 2rem;
    opacity: 0.9;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
  }
  .template-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .template-info h4 {
    font-size: 0.95rem;
    margin: 0;
  }
  .badge-free {
    font-size: 0.7rem;
    background: #ffffff1a;
    padding: 3px 8px;
    border-radius: 12px;
  }
  .badge-pro {
    font-size: 0.7rem;
    background: var(--primary);
    color: white;
    padding: 3px 8px;
    border-radius: 12px;
    font-weight: bold;
  }
  @media (max-width: 768px) {
    .templates-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<style is:global>
  .invoice-app {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 40px;
  }
  
  .invoice-editor {
    padding: 40px;
  }
  
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-top: 30px;
  }
  
  .form-section h3, .items-section h3 {
    margin-bottom: 20px;
    color: var(--primary);
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
  }
  
  .form-section label {
    margin-top: 15px;
  }
  
  @media (max-width: 900px) {
    .invoice-app {
      grid-template-columns: 1fr;
    }
    
    .form-grid {
      grid-template-columns: 1fr;
    }
    
    .item-row {
      flex-wrap: wrap;
    }
  }
</style>
