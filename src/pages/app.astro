---
import Layout from '../layouts/Layout.astro';
import InvoiceApp from '../components/InvoiceApp';

import TemplateShowcase from '../components/TemplateShowcase.astro';

// Server-side authentication check
const accessToken = Astro.cookies.get('sb-access-token');
const refreshToken = Astro.cookies.get('sb-refresh-token');

if (!accessToken || !refreshToken) {
  return Astro.redirect('/login');
}

import { supabase } from '../lib/supabase';

await supabase.auth.setSession({
  access_token: accessToken.value,
  refresh_token: refreshToken.value,
});

const { data: { user } } = await supabase.auth.getUser();

let isPro = false;
if (user) {
  if (user.email === 'thomasmayoraz@yahoo.com') {
    isPro = true;
  } else {
    const { data: profile } = await supabase
      .from('profiles')
      .select('is_pro')
      .eq('id', user.id)
      .single();
    isPro = profile?.is_pro || false;
  }
}
---

<Layout title="FactureArtisan | Éditeur de facture">
  <div class="container" style="padding: 40px 24px;">
    <div class="app-header-simple" style="margin-bottom: 30px;">
      <h1 class="text-gradient">Nouvelle Facture</h1>
      <p style="color: var(--text-muted);">Remplissez les champs ci-dessous pour générer votre document PDF.</p>
    </div>

    <!-- Sélecteur de modèles (Templates Showcase) -->
    <h3 style="margin-bottom: 15px; font-size: 1.1rem; color: var(--text-main);">Choisissez votre modèle</h3>
    <TemplateShowcase />
    
    <!-- Render React app exclusively on client-side to prevent SSR issues with @react-pdf/renderer -->
    <InvoiceApp client:only="react" initialIsPro={isPro} />
  </div>
</Layout>

<style is:global>
  .invoice-app {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 40px;
  }
  
  .invoice-editor {
    padding: 40px;
  }
  
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-top: 30px;
  }
  
  .form-section h3, .items-section h3 {
    margin-bottom: 20px;
    color: var(--primary);
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
  }
  
  .form-section label {
    margin-top: 15px;
  }
  
  @media (max-width: 900px) {
    .invoice-app {
      grid-template-columns: 1fr;
    }
    
    .form-grid {
      grid-template-columns: 1fr;
    }
    
    .item-row {
      flex-wrap: wrap;
    }
  }
</style>
