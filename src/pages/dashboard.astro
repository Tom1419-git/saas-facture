---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

const accessToken = Astro.cookies.get('sb-access-token');
const refreshToken = Astro.cookies.get('sb-refresh-token');

if (!accessToken || !refreshToken) {
  return Astro.redirect('/login');
}

await supabase.auth.setSession({
  access_token: accessToken.value,
  refresh_token: refreshToken.value,
});

const { data: { user } } = await supabase.auth.getUser();
const isAdmin = user?.email === 'thomasmayoraz@yahoo.com';

let isPro = false;
let invoices = [];

if (user) {
  const { data: profile } = await supabase
    .from('profiles')
    .select('is_pro')
    .eq('id', user.id)
    .single();
    
  isPro = profile?.is_pro || false;

  const { data: invData } = await supabase
    .from('invoices')
    .select('*')
    .eq('user_id', user.id)
    .order('created_at', { ascending: false })
    .limit(10);
    
  if (invData) invoices = invData;
}
---

<Layout title="FactureArtisan | Dashboard">
  <div class="container" style="padding: 60px 24px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; flex-wrap: wrap; gap: 20px;">
      <div>
        <h1 class="text-gradient">Tableau de bord</h1>
        <p style="color: var(--text-muted);">Bienvenue ! Voici un récapitulatif de votre activité.</p>
      </div>
      <div style="display: flex; gap: 15px;">
        {isAdmin && (
          <a href="/admin" class="btn btn-secondary" style="border-color: var(--danger); color: var(--danger);">⚙️ Admin</a>
        )}
        <a href="/app" class="btn btn-primary">+ Nouvelle Facture</a>
      </div>
    </div>
    
    <div class="glass-card" style="padding: 30px;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h3 style="margin: 0;">Vos factures récentes</h3>
        {!isPro && !isAdmin && (
          <span style="font-size: 0.8rem; background: rgba(255,255,255,0.1); padding: 4px 10px; border-radius: 20px;">
            Gratuit ({invoices.length}/3)
          </span>
        )}
      </div>
      
      {invoices.length > 0 ? (
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse; text-align: left; min-width: 500px;">
            <thead>
              <tr style="border-bottom: 1px solid var(--border);">
                <th style="padding: 10px 0; color: var(--text-muted); font-weight: normal;">Numéro</th>
                <th style="padding: 10px 0; color: var(--text-muted); font-weight: normal;">Client</th>
                <th style="padding: 10px 0; color: var(--text-muted); font-weight: normal;">Date</th>
                <th style="padding: 10px 0; color: var(--text-muted); font-weight: normal; text-align: right;">Montant</th>
              </tr>
            </thead>
            <tbody>
              {invoices.map((inv: any) => (
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                  <td style="padding: 15px 0;"><strong>{inv.invoice_number}</strong></td>
                  <td style="padding: 15px 0;">{inv.client_name}</td>
                  <td style="padding: 15px 0;">{new Date(inv.created_at).toLocaleDateString('fr-CH')}</td>
                  <td style="padding: 15px 0; text-align: right;">{inv.total_amount.toFixed(2)} CHF</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div style="text-align: center; padding: 30px 0;">
          <p style="color: var(--text-muted); margin-bottom: 20px;">Vous n'avez pas encore généré de facture.</p>
          <a href="/app" class="btn btn-primary">Créer ma première facture</a>
        </div>
      )}
      
      {!isPro && !isAdmin && (
        <div style="margin-top: 30px; text-align: center; padding-top: 20px; border-top: 1px dashed var(--border);">
          <p style="color: var(--text-muted); margin-bottom: 15px; font-size: 0.9rem;">
            Avec le compte gratuit, vous êtes limité à 3 factures générées. L'historique vous permet juste de retrouver vos numéros.
          </p>
          <a href="/pro" class="btn btn-secondary" style="font-size: 0.9rem;">Débloquer la version Pro (Illimité)</a>
        </div>
      )}
    </div>

    <!-- ZONE DE DANGER (RGPD) -->
    <div style="margin-top: 60px; padding-top: 30px; border-top: 1px solid rgba(255, 50, 50, 0.2);">
      <h3 style="color: #ff6b6b; margin-bottom: 10px;">Zone de danger</h3>
      <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 20px;">
        Conformément au RGPD, vous avez le droit de demander la suppression totale de vos données personnelles.
      </p>
      <button id="trigger-delete-btn" class="btn" style="background: rgba(255, 50, 50, 0.1); color: #ff6b6b; border: 1px solid rgba(255, 50, 50, 0.3); padding: 8px 16px;">
        Demander la suppression de mon compte
      </button>
    </div>

    <!-- MODAL DE CONFIRMATION -->
    <div id="delete-modal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 1000; justify-content: center; align-items: center;">
      <div class="glass-card" style="padding: 30px; max-width: 400px; width: 90%; border-color: rgba(255,50,50,0.3);">
        <h3 style="color: #ff6b6b; margin-bottom: 15px;">Demande de suppression</h3>
        <p style="color: var(--text-muted); margin-bottom: 20px; font-size: 0.95rem;">
          Votre demande de suppression sera envoyée à notre équipe et traitée sous 30 jours, conformément au RGPD.
          Toutes vos données et factures seront définitivement effacées.
        </p>
        
        <div style="display: flex; gap: 10px;">
          <button id="cancel-delete-btn" class="btn btn-secondary" style="flex: 1;">Annuler</button>
          <a href="mailto:thomasmayoraz@yahoo.com?subject=Demande%20de%20suppression%20de%20compte%20RGPD&body=Bonjour%2C%0A%0AJe%20souhaite%20exercer%20mon%20droit%20à%20l'oubli%20et%20demande%20la%20suppression%20de%20mon%20compte%20FactureArtisan%20ainsi%20que%20toutes%20les%20données%20associées.%0A%0AMerci." id="confirm-delete-btn" class="btn" style="flex: 1; background: #ff6b6b; color: white; text-decoration: none; text-align: center;">Confirmer</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { supabase } from '../lib/supabase';

    const triggerBtn = document.getElementById('trigger-delete-btn');
    const modal = document.getElementById('delete-modal');
    const cancelBtn = document.getElementById('cancel-delete-btn');
    const confirmBtn = document.getElementById('confirm-delete-btn');

    if (triggerBtn && modal && cancelBtn && confirmBtn) {
      triggerBtn.addEventListener('click', () => {
        modal.style.display = 'flex';
      });

      cancelBtn.addEventListener('click', () => {
        modal.style.display = 'none';
      });

      confirmBtn.addEventListener('click', () => {
        // Just hide the modal, the mailto link will open the email client
        setTimeout(() => {
          modal.style.display = 'none';
        }, 500);
      });
    }
  </script>
</Layout>
