---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

const accessToken = Astro.cookies.get('sb-access-token');
const refreshToken = Astro.cookies.get('sb-refresh-token');

if (!accessToken || !refreshToken) {
  return Astro.redirect('/login');
}

await supabase.auth.setSession({
  access_token: accessToken.value,
  refresh_token: refreshToken.value,
});

const { data: { user } } = await supabase.auth.getUser();
const isAdmin = user?.email === 'thomasmayoraz@yahoo.com';
---

<Layout title="FactureArtisan | Dashboard">
  <div class="container" style="padding: 60px 24px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px;">
      <div>
        <h1 class="text-gradient">Tableau de bord</h1>
        <p style="color: var(--text-muted);">Bienvenue ! Voici un récapitulatif de votre activité.</p>
      </div>
      <div style="display: flex; gap: 15px;">
        {isAdmin && (
          <a href="/admin" class="btn btn-secondary" style="border-color: var(--danger); color: var(--danger);">⚙️ Admin</a>
        )}
        <a href="/app" class="btn btn-primary">+ Nouvelle Facture</a>
      </div>
    </div>
    
    <div class="glass-card" style="padding: 40px; text-align: center;">
      <h3 style="margin-bottom: 15px;">Vos factures récentes</h3>
      <p style="color: var(--text-muted); margin-bottom: 30px;">
        Vous utilisez actuellement le compte gratuit. L'historique des factures n'est pas sauvegardé dans le cloud.
      </p>
      <a href="/pro" class="btn btn-secondary">Débloquer la version Pro</a>
    </div>

    <!-- ZONE DE DANGER (RGPD) -->
    <div style="margin-top: 60px; padding-top: 30px; border-top: 1px solid rgba(255, 50, 50, 0.2);">
      <h3 style="color: #ff6b6b; margin-bottom: 10px;">Zone de danger</h3>
      <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 20px;">
        La suppression de votre compte est irréversible. Toutes vos données personnelles et vos factures seront définitivement effacées conformément au RGPD.
      </p>
      <button id="trigger-delete-btn" class="btn" style="background: rgba(255, 50, 50, 0.1); color: #ff6b6b; border: 1px solid rgba(255, 50, 50, 0.3); padding: 8px 16px;">
        Supprimer mon compte
      </button>
    </div>

    <!-- MODAL DE CONFIRMATION -->
    <div id="delete-modal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 1000; justify-content: center; align-items: center;">
      <div class="glass-card" style="padding: 30px; max-width: 400px; width: 90%; border-color: rgba(255,50,50,0.3);">
        <h3 style="color: #ff6b6b; margin-bottom: 15px;">Êtes-vous sûr(e) ?</h3>
        <p style="color: var(--text-muted); margin-bottom: 20px; font-size: 0.95rem;">
          Cette action va effacer votre compte et vos données instantanément. 
          Veuillez taper <strong>SUPPRIMER</strong> ci-dessous pour confirmer.
        </p>
        <input type="text" id="delete-confirm-input" placeholder="Tapez SUPPRIMER" class="form-control" style="margin-bottom: 20px; text-align: center;" />
        
        <div style="display: flex; gap: 10px;">
          <button id="cancel-delete-btn" class="btn btn-secondary" style="flex: 1;">Annuler</button>
          <button id="confirm-delete-btn" class="btn" disabled style="flex: 1; background: #ff6b6b; color: white; opacity: 0.5; cursor: not-allowed;">Confirmer</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { supabase } from '../lib/supabase';

    const triggerBtn = document.getElementById('trigger-delete-btn');
    const modal = document.getElementById('delete-modal');
    const cancelBtn = document.getElementById('cancel-delete-btn');
    const confirmBtn = document.getElementById('confirm-delete-btn') as HTMLButtonElement;
    const input = document.getElementById('delete-confirm-input') as HTMLInputElement;

    if (triggerBtn && modal && cancelBtn && confirmBtn && input) {
      triggerBtn.addEventListener('click', () => {
        modal.style.display = 'flex';
        input.value = '';
        confirmBtn.disabled = true;
        confirmBtn.style.opacity = '0.5';
        confirmBtn.style.cursor = 'not-allowed';
      });

      cancelBtn.addEventListener('click', () => {
        modal.style.display = 'none';
      });

      input.addEventListener('input', (e) => {
        const val = (e.target as HTMLInputElement).value;
        if (val === 'SUPPRIMER') {
          confirmBtn.disabled = false;
          confirmBtn.style.opacity = '1';
          confirmBtn.style.cursor = 'pointer';
        } else {
          confirmBtn.disabled = true;
          confirmBtn.style.opacity = '0.5';
          confirmBtn.style.cursor = 'not-allowed';
        }
      });

      confirmBtn.addEventListener('click', async () => {
        try {
          confirmBtn.innerText = 'Suppression...';
          confirmBtn.disabled = true;
          
          // Call the custom Postgres function to delete the user completely
          const { error } = await supabase.rpc('delete_user_account');
          
          if (error) {
            console.error("Erreur RPC:", error);
            alert("Erreur lors de la suppression de votre compte. Veuillez réessayer.");
            confirmBtn.innerText = 'Confirmer';
            confirmBtn.disabled = false;
            return;
          }

          // Effacer cookies et session client
          await supabase.auth.signOut();
          document.cookie = 'sb-access-token=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
          document.cookie = 'sb-refresh-token=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
          
          alert("Votre compte a été supprimé avec succès.");
          window.location.href = '/';

        } catch (err) {
          console.error(err);
          alert("Une erreur inattendue est survenue.");
        }
      });
    }
  </script>
</Layout>
