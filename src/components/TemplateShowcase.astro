---
// TemplateShowcase.astro
---
<div class="templates-showcase" style="margin-bottom: 40px;">
  <div class="templates-grid">
    
    <!-- Modèle Classique (Gratuit) -->
    <div class="template-card active">
      <div class="template-preview-wrapper">
        <div class="mini-invoice standard-invoice">
          <div class="inv-header">
            <div class="inv-title">FACTURE</div>
            <div class="inv-meta">
              <div class="meta-line"></div>
              <div class="meta-line short"></div>
            </div>
            <div class="inv-logo"></div>
          </div>
          <div class="inv-addresses">
            <div class="address-block">
              <div class="addr-line bold"></div>
              <div class="addr-line"></div>
              <div class="addr-line"></div>
            </div>
            <div class="address-block right">
              <div class="addr-line bold"></div>
              <div class="addr-line"></div>
              <div class="addr-line"></div>
            </div>
          </div>
          <div class="inv-table">
            <div class="table-header"></div>
            <div class="table-row"></div>
            <div class="table-row"></div>
            <div class="table-row"></div>
          </div>
          <div class="inv-totals">
            <div class="total-line"></div>
            <div class="total-line"></div>
            <div class="total-line grand"></div>
          </div>
        </div>
      </div>
      <div class="template-info">
        <h4>Standard</h4>
        <span class="badge-free">Gratuit</span>
      </div>
    </div>

    <!-- Modèle Élégant + Logo (Pro) -->
    <a href="/pro" class="template-card locked">
      <div class="template-preview-wrapper">
        <div class="mini-invoice logo-invoice">
          <div class="inv-header">
            <div class="inv-logo-color"></div>
            <div class="inv-title">FACTURE</div>
            <div class="inv-meta">
              <div class="meta-line"></div>
              <div class="meta-line short"></div>
            </div>
          </div>
          <div class="inv-addresses">
            <div class="address-block" style="opacity: 0">
              <!-- Spacer -->
            </div>
            <div class="address-block right">
              <div class="addr-line bold"></div>
              <div class="addr-line"></div>
              <div class="addr-line"></div>
            </div>
          </div>
          <div class="inv-addresses">
            <div class="address-block">
              <div class="addr-line bold"></div>
              <div class="addr-line"></div>
              <div class="addr-line"></div>
            </div>
          </div>
          <div class="inv-table">
            <div class="table-header"></div>
            <div class="table-row"></div>
            <div class="table-row"></div>
          </div>
        </div>
        <div class="lock-overlay">
          <div class="lock-icon">🔒</div>
        </div>
      </div>
      <div class="template-info">
        <h4>Élégant + Logo</h4>
        <span class="badge-pro">PRO</span>
      </div>
    </a>

    <!-- Modèle Enveloppe Suisse (Pro) -->
    <a href="/pro" class="template-card locked">
      <div class="template-preview-wrapper">
        <div class="mini-invoice envelope-invoice">
          <div class="env-top-section">
            <div class="env-left">
              <div class="inv-logo-color small"></div>
              <div class="inv-title">FACTURE</div>
              <div class="meta-line"></div>
            </div>
            <div class="env-window">
              <div class="env-sender-small"></div>
              <div class="addr-line bold"></div>
              <div class="addr-line"></div>
              <div class="addr-line"></div>
            </div>
          </div>
          
          <div class="inv-table">
            <div class="table-header"></div>
            <div class="table-row"></div>
            <div class="table-row"></div>
          </div>
          <div class="inv-totals">
            <div class="total-line grand"></div>
          </div>
        </div>
        <div class="lock-overlay">
          <div class="lock-icon">🔒</div>
        </div>
      </div>
      <div class="template-info">
        <h4>Format Enveloppe (C5)</h4>
        <span class="badge-pro">PRO</span>
      </div>
    </a>

  </div>
  <p class="showcase-tip">
    💡 <strong>Astuce :</strong> Le placement de l'adresse et le téléchargement de votre logo sont exclusifs à la version Pro.
  </p>
</div>

<style>
  .templates-showcase {
    width: 100%;
  }
  .templates-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    text-align: left;
  }
  .template-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 15px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    color: var(--text-main);
    display: flex;
    flex-direction: column;
  }
  .template-card:hover {
    border-color: var(--primary);
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }
  .template-card.active {
    border-color: var(--primary);
    background: rgba(94, 106, 210, 0.05);
    box-shadow: 0 0 0 1px var(--primary);
  }
  
  .template-preview-wrapper {
    height: 140px;
    background: #0a0a0c;
    border-radius: 8px;
    margin-bottom: 15px;
    position: relative;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    border: 1px solid rgba(255,255,255,0.05);
  }
  
  /* Mini Invoices Base */
  .mini-invoice {
    width: 90px;
    height: 120px;
    border-radius: 4px;
    padding: 6px;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    transition: transform 0.3s ease;
    overflow: hidden;
    position: relative;
    background: #ffffff;
    border: 1px solid #ddd;
  }
  .template-card:hover .mini-invoice {
    transform: scale(1.05) translateY(-2px);
  }
  
  /* Shared Invoice Elements */
  .inv-header { display: flex; flex-direction: column; align-items: flex-start; margin-bottom: 8px; position: relative; }
  .inv-title { width: 30px; height: 5px; background: #333; margin-bottom: 3px; }
  .inv-meta { display: flex; flex-direction: column; gap: 2px; }
  .meta-line { width: 25px; height: 2px; background: #bbb; }
  .meta-line.short { width: 15px; }
  .inv-logo { position: absolute; right: 0; top: 0; width: 18px; height: 18px; background: #eee; border-radius: 2px; border: 1px solid #ddd; }
  
  .inv-addresses { display: flex; justify-content: space-between; margin-bottom: 8px; }
  .address-block { display: flex; flex-direction: column; gap: 2px; width: 45%; }
  .address-block.right { align-items: flex-end; }
  .addr-line { width: 100%; height: 2px; background: #eee; }
  .addr-line.bold { background: #999; margin-bottom: 2px; height: 3px; width: 80%; }
  
  .inv-table { margin-bottom: auto; border: 1px solid #eee; border-radius: 2px; }
  .table-header { height: 4px; background: #f5f5f5; border-bottom: 1px solid #eee; }
  .table-row { height: 4px; border-bottom: 1px solid #fafafa; margin: 2px 0; background: #fdfdfd; }
  
  .inv-totals { display: flex; flex-direction: column; gap: 2px; align-items: flex-end; margin-top: 4px; }
  .total-line { width: 30px; height: 3px; background: #eee; }
  .total-line.grand { width: 40px; height: 4px; background: #333; margin-top: 2px; }

  /* Logo Invoice Details */
  .logo-invoice .inv-header { margin-bottom: 4px; }
  .logo-invoice .inv-logo-color { width: 20px; height: 10px; background: var(--primary); border-radius: 2px; margin-bottom: 4px; }
  
  /* Envelope Invoice Details */
  .envelope-invoice .env-top-section { display: flex; justify-content: space-between; margin-bottom: 15px; }
  .envelope-invoice .env-left { width: 40%; }
  .envelope-invoice .inv-logo-color.small { width: 15px; height: 6px; background: var(--primary); border-radius: 1px; margin-bottom: 3px; }
  .envelope-invoice .env-window { width: 50%; padding-left: 5px; border: 1px dashed #ccc; padding: 2px; background: #fcfcfc; }
  .envelope-invoice .env-sender-small { width: 30%; height: 1px; background: #ccc; margin-bottom: 3px; border-bottom: 1px solid #ddd; padding-bottom: 1px; }

  /* Lock Overlay */
  .lock-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 12, 0.6);
    backdrop-filter: blur(2px);
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 1;
    transition: background 0.3s ease;
  }
  .template-card:hover .lock-overlay {
    background: rgba(10, 10, 12, 0.4);
  }
  .lock-icon {
    font-size: 1.8rem;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.5));
    transform: translateY(0);
    transition: transform 0.3s ease;
  }
  .template-card:hover .lock-icon {
    transform: scale(1.1);
  }
  
  .template-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }
  .template-info h4 {
    font-size: 0.95rem;
    margin: 0;
    font-weight: 600;
  }
  .badge-free {
    font-size: 0.7rem;
    background: rgba(255,255,255,0.1);
    padding: 4px 8px;
    border-radius: 12px;
    font-weight: 500;
  }
  .badge-pro {
    font-size: 0.7rem;
    background: var(--primary);
    color: white;
    padding: 4px 8px;
    border-radius: 12px;
    font-weight: bold;
    box-shadow: 0 2px 8px var(--primary-glow);
  }
  .showcase-tip {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 15px;
    text-align: center;
  }
  
  @media (max-width: 768px) {
    .templates-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
