---
import '../styles/main.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Générateur de factures professionnel pour artisans et indépendants." } = Astro.props;

// Read JWT to get email without making a network request (Cloudflare compatible)
const accessToken = Astro.cookies.get('sb-access-token')?.value;
let userEmail = null;
if (accessToken) {
  try {
    const payload = JSON.parse(atob(accessToken.split('.')[1]));
    userEmail = payload.email;
  } catch (e) {
    console.error("Erreur décodage JWT", e);
  }
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <header class="app-header">
      <div class="container header-content">
        <a href="/" class="logo">
          <span class="text-gradient-primary">Facture</span>Artisan
        </a>
        <nav>
          {userEmail ? (
            <div style="display: flex; align-items: center; gap: 15px;">
              <span style="color: var(--text-muted); font-size: 0.9rem;">{userEmail}</span>
              <a href="/dashboard" class="btn btn-secondary" style="padding: 6px 14px;">Dashboard</a>
            </div>
          ) : (
            <>
              <a href="/login" class="btn btn-secondary" style="padding: 8px 16px; margin-right: 12px;">Se connecter</a>
              <a href="/signup" class="btn btn-primary" style="padding: 8px 16px;">Créer un compte</a>
            </>
          )}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="app-footer">
      <div class="container footer-content">
        <p>&copy; {new Date().getFullYear()} FactureArtisan. Créé avec passion par <a href="https://mayoraz-net.ch" target="_blank" rel="noopener noreferrer">Thomas Mayoraz</a>.</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .app-header {
    padding: 20px 0;
    border-bottom: 1px solid var(--border);
    background: rgba(10, 10, 12, 0.8);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  
  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-main);
  }
  
  .app-footer {
    padding: 40px 0;
    margin-top: 80px;
    border-top: 1px solid var(--border);
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
</style>
