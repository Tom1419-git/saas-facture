---
import '../styles/main.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Générateur de factures professionnel pour artisans et indépendants. Gratuit, rapide et conforme aux normes suisses." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://facture.mayoraz-net.ch');

// Read JWT to get email without making a network request (Cloudflare compatible)
const accessToken = Astro.cookies.get('sb-access-token')?.value;
let userEmail = null;
if (accessToken) {
  try {
    const payload = JSON.parse(atob(accessToken.split('.')[1]));
    userEmail = payload.email;
  } catch (e) {
    console.error("Erreur décodage JWT", e);
  }
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
    
    <!-- Open Graph / Social Media -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="FactureArtisan" />
    <meta property="og:locale" content="fr_CH" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <header class="app-header">
      <div class="container header-content">
        <a href="/" class="logo">
          <span class="text-gradient-primary">Facture</span>Artisan
        </a>
        <nav>
          {userEmail ? (
            <div style="display: flex; align-items: center; gap: 15px;">
              <span class="nav-email">{userEmail}</span>
              <a href="/dashboard" class="btn btn-secondary" style="padding: 6px 14px;">Dashboard</a>
              <button id="logout-btn" class="btn" style="padding: 6px 14px; background: rgba(255,50,50,0.1); color: #ff6b6b; border: 1px solid rgba(255,50,50,0.2);">Déconnexion</button>
            </div>
          ) : (
            <>
              <a href="/login" class="btn btn-secondary" style="padding: 8px 16px; margin-right: 12px;">Se connecter</a>
              <a href="/signup" class="btn btn-primary" style="padding: 8px 16px;">Créer un compte</a>
            </>
          )}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="app-footer">
      <div class="container footer-content">
        <p>&copy; {new Date().getFullYear()} FactureArtisan. Créé avec passion par <a href="https://mayoraz-net.ch" target="_blank" rel="noopener noreferrer">Thomas Mayoraz</a>.</p>
      </div>
    </footer>
    
    <script>
      import { supabase } from '../lib/supabase';
      
      const logoutBtn = document.getElementById('logout-btn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', async () => {
          // 1. Clear Supabase auth session
          await supabase.auth.signOut();
          
          // 2. Clear cookies
          document.cookie = 'sb-access-token=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
          document.cookie = 'sb-refresh-token=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
          
          // 3. Redirect to home
          window.location.href = '/';
        });
      }
    </script>
  </body>
</html>

<style>
  .app-header {
    padding: 20px 0;
    border-bottom: 1px solid var(--border);
    background: rgba(10, 10, 12, 0.8);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  
  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-main);
  }
  
  .nav-email {
    color: var(--text-muted);
    font-size: 0.9rem;
    display: none;
  }
  
  @media (min-width: 600px) {
    .nav-email {
      display: inline;
    }
  }
  
  .app-footer {
    padding: 40px 0;
    margin-top: 80px;
    border-top: 1px solid var(--border);
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
</style>

